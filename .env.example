# Usage:
#   cp .env.example .env
#   # Edit .env with your API keys

# ── API Authentication ────────────────────────────────────────────────────────
# Set a secret key to protect all /api/v1/* endpoints.
# Leave empty (or unset) to disable auth in local/dev mode.
# API_KEY=your-secret-key-here

# ── Neo4j ──────────────────────────────────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
# NEO4J_HTTP_PORT=7474
# NEO4J_BOLT_PORT=7687

# ── LLM Provider API Keys (set at least one) ──────────────────────────────────
# OpenAI direct (for gpt-* models):
# OPENAI_API_KEY=sk-...

# OpenRouter (for provider/model format):
# OPENROUTER_API_KEY=sk-or-...

# Anthropic (for claude-* models):
# ANTHROPIC_API_KEY=sk-ant-...

# ── LLM Model Selection ───────────────────────────────────────────────────────
# LLM_MODEL_REASONING=gpt-5.4-2026-03-05
# LLM_MODEL_EXTRACTION=gpt-5.4-nano-2026-03-17
# LLM_MODEL_MIDTIER=gpt-5.4-mini-2026-03-17
# LLM_MAX_TOKENS_REASONING=4096
# LLM_MAX_TOKENS_EXTRACTION=8192

# ── API Server ─────────────────────────────────────────────────────────────────
# API_PORT=8000
# LOG_LEVEL=INFO
