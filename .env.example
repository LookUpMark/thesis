# ══════════════════════════════════════════════════════════════════════════════
# SemanticMesh — Environment Configuration Template
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in your API keys:
#   cp .env.example .env
#
# All values with "CHANGE_ME" or "sk-..." placeholders MUST be replaced.
# Commented-out lines show optional settings with their defaults.

# ── API Authentication ────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty/unset to disable auth (local dev only — NOT for production).
API_KEY=CHANGE_ME

# ── Neo4j ──────────────────────────────────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME
# NEO4J_HTTP_PORT=7474
# NEO4J_BOLT_PORT=7687

# ── LLM Provider API Keys (set the key for your chosen provider) ──────────────
# OpenAI direct (for provider=openai):
OPENAI_API_KEY=sk-proj-CHANGE_ME

# OpenRouter (for provider=openrouter):
# OPENROUTER_API_KEY=sk-or-v1-CHANGE_ME

# Anthropic (for provider=anthropic):
# ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# Google Gemini (for provider=google):
# GOOGLE_API_KEY=CHANGE_ME

# Groq (for provider=groq):
# GROQ_API_KEY=gsk_CHANGE_ME

# Mistral (for provider=mistral):
# MISTRAL_API_KEY=CHANGE_ME

# DeepSeek (for provider=deepseek):
# DEEPSEEK_API_KEY=CHANGE_ME

# xAI / Grok (for provider=xai):
# XAI_API_KEY=CHANGE_ME

# Cohere (for provider=cohere):
# COHERE_API_KEY=CHANGE_ME

# ── Explicit Per-Tier LLM Configuration ───────────────────────────────────────
# Each tier has 4 explicit variables: PROVIDER, MODEL, ENDPOINT, EFFORT.
# Provider is REQUIRED — no auto-detection from model name.
#
# Provider options: openai | openrouter | anthropic | lmstudio | ollama |
#   google | bedrock | azure | groq | mistral | together | deepseek | xai |
#   nvidia | cohere | huggingface
#
# Endpoint: leave empty to use the provider's default API URL.
# Effort: reasoning_effort for OpenAI reasoning models (o-series, gpt-5*).
#   Options: minimal | low | medium | high | (empty = disabled)
#   Only effective for openai and openrouter providers.

# Reasoning tier — mapping, validation, Cypher generation/healing
LLM_PROVIDER_REASONING=openai
LLM_MODEL_REASONING=gpt-5.4-nano-2026-03-17
LLM_ENDPOINT_REASONING=
LLM_EFFORT_REASONING=high

# Extraction tier — triplet extraction from PDF chunks
LLM_PROVIDER_EXTRACTION=openai
LLM_MODEL_EXTRACTION=gpt-5-nano-2025-08-07
LLM_ENDPOINT_EXTRACTION=
LLM_EFFORT_EXTRACTION=minimal

# Generation tier — answer generation (defaults to reasoning model if empty)
LLM_PROVIDER_GENERATION=openai
LLM_MODEL_GENERATION=
LLM_ENDPOINT_GENERATION=
LLM_EFFORT_GENERATION=

# Mid-tier — RAG mapping, Actor-Critic, hallucination grading
LLM_PROVIDER_MIDTIER=openai
LLM_MODEL_MIDTIER=gpt-5-nano-2025-08-07
LLM_ENDPOINT_MIDTIER=
LLM_EFFORT_MIDTIER=medium

# Token limits
LLM_MAX_TOKENS_REASONING=4096
LLM_MAX_TOKENS_EXTRACTION=8192

# AI Judge model (used by scripts/run_ai_judge.py):
JUDGE_MODEL=gpt-5.4-nano-2026-03-17

# ── Local LLM Endpoints ──────────────────────────────────────────────────────
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Legacy Provider Override (DEPRECATED — use per-tier vars above) ───────────
# Force all models through a single provider.
# LLM_PROVIDER=auto

# ── API Server ─────────────────────────────────────────────────────────────────
# API_PORT=8000
# LOG_LEVEL=INFO
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Observability: LangSmith ──────────────────────────────────────────────────
# Enable LangSmith tracing (LangChain auto-sends traces when these are set):
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-CHANGE_ME
# LANGCHAIN_PROJECT=semanticmesh

# ── Observability: Langfuse ───────────────────────────────────────────────────
# Enable Langfuse tracing (self-hosted or cloud.langfuse.com):
# LANGFUSE_PUBLIC_KEY=pk-lf-CHANGE_ME
# LANGFUSE_SECRET_KEY=sk-lf-CHANGE_ME
# LANGFUSE_HOST=https://cloud.langfuse.com
