# ══════════════════════════════════════════════════════════════════════════════
# SemanticMesh — Environment Configuration Template
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in your API keys:
#   cp .env.example .env
#
# All values with "CHANGE_ME" or "sk-..." placeholders MUST be replaced.
# Commented-out lines show optional settings with their defaults.

# ── API Authentication ────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty/unset to disable auth (local dev only — NOT for production).
API_KEY=CHANGE_ME

# ── Neo4j ──────────────────────────────────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME
# NEO4J_HTTP_PORT=7474
# NEO4J_BOLT_PORT=7687

# ── LLM Provider API Keys (set at least one) ──────────────────────────────────
# OpenAI direct (for gpt-* models):
OPENAI_API_KEY=sk-proj-CHANGE_ME

# OpenRouter (for provider/model format, e.g. "openai/gpt-4.1"):
# OPENROUTER_API_KEY=sk-or-v1-CHANGE_ME

# Anthropic (for claude-* models):
# ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# Google Gemini:
# GOOGLE_API_KEY=CHANGE_ME

# Groq (for groq/* models):
# GROQ_API_KEY=gsk_CHANGE_ME

# Mistral:
# MISTRAL_API_KEY=CHANGE_ME

# DeepSeek:
# DEEPSEEK_API_KEY=CHANGE_ME

# xAI (Grok):
# XAI_API_KEY=CHANGE_ME

# Cohere:
# COHERE_API_KEY=CHANGE_ME

# ── Local LLM Endpoints (Ollama / LM Studio) ──────────────────────────────────
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# OLLAMA_BASE_URL=http://localhost:11434/v1

# ── LLM Model Selection ───────────────────────────────────────────────────────
# Models are auto-routed by prefix (gpt-* → OpenAI, claude-* → Anthropic, etc.)
# Or set LLM_PROVIDER to force a single provider for all models.
LLM_MODEL_REASONING=gpt-4.1
LLM_MODEL_EXTRACTION=gpt-4.1-nano
LLM_MODEL_MIDTIER=gpt-4.1-nano
LLM_MAX_TOKENS_REASONING=4096
LLM_MAX_TOKENS_EXTRACTION=8192

# AI Judge model (used by scripts/run_ai_judge.py):
JUDGE_MODEL=gpt-4.1

# ── LLM Provider Override ─────────────────────────────────────────────────────
# Force all models through a single provider (default: auto-detect from prefix)
# Options: auto, openai, openrouter, anthropic, ollama, lmstudio, groq,
#           google, mistral, together, deepseek, xai, nvidia, bedrock, azure
# LLM_PROVIDER=auto

# ── API Server ─────────────────────────────────────────────────────────────────
# API_PORT=8000
# LOG_LEVEL=INFO
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Observability: LangSmith ──────────────────────────────────────────────────
# Enable LangSmith tracing (LangChain auto-sends traces when these are set):
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls-CHANGE_ME
# LANGCHAIN_PROJECT=semanticmesh

# ── Observability: Langfuse ───────────────────────────────────────────────────
# Enable Langfuse tracing (self-hosted or cloud.langfuse.com):
# LANGFUSE_PUBLIC_KEY=pk-lf-CHANGE_ME
# LANGFUSE_SECRET_KEY=sk-lf-CHANGE_ME
# LANGFUSE_HOST=https://cloud.langfuse.com
