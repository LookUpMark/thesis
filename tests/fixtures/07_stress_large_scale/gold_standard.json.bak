{
  "dataset_name": "Enterprise ERP Stress Test",
  "dataset_id": "07_stress_large_scale",
  "version": "1.0",
  "description": "Large-scale stress testing dataset with 37 tables, complex multi-hop queries, and enterprise scenarios",
  "domain": "Enterprise Resource Planning (ERP)",
  "created_date": "2024-03-23",
  "qa_pairs": [
    {
      "id": "QA-001",
      "question": "What are the top 5 customers by total order value in the last 90 days, and what is their credit score and payment history?",
      "answer_type": "aggregation",
      "tables_involved": ["customer", "customer_type", "sales_order", "invoice", "payment"],
      "complexity": "medium",
      "expected_result_format": "List of customers with order totals, credit scores, and payment metrics",
      "query_pattern": "JOIN + GROUP BY + ORDER BY + date filter"
    },
    {
      "id": "QA-002",
      "question": "Which products have the highest scrap rate in production, and what is the total cost of scrap for each product in the last 6 months?",
      "answer_type": "aggregation",
      "tables_involved": ["product", "work_order", "work_order_material", "inventory_transaction"],
      "complexity": "medium",
      "expected_result_format": "Products ranked by scrap rate with total scrap cost",
      "query_pattern": "JOIN + GROUP BY + HAVING + calculation"
    },
    {
      "id": "QA-003",
      "question": "Find all suppliers that have quality inspection failure rates above 5% and identify which products they supply.",
      "answer_type": "filtering",
      "tables_involved": ["supplier", "purchase_order", "purchase_order_line", "product", "purchase_receipt", "quality_inspection"],
      "complexity": "high",
      "expected_result_format": "Suppliers with failure rates and their supplied products",
      "query_pattern": "JOIN + subquery + HAVING + aggregation"
    },
    {
      "id": "QA-004",
      "question": "What is the complete bill of materials for product 'Industrial Assembly Robot ARM-500' including all sub-assemblies and raw materials?",
